################################################################################
# SiteWard Backend – Environment Variables
################################################################################

# Server
PORT=5000
NODE_ENV=development

# Supabase — get these from your Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Groq AI — get from https://console.groq.com
# Used for SEO suggestions and fix generation.
# If not set, the app falls back to rule-based suggestions.
GROQ_API_KEY=your-groq-api-key

# GitHub (optional) — used for PR creation when auto-fixing
GITHUB_TOKEN=your-github-token

# CORS — set to your frontend URL in production
# ALLOWED_ORIGIN=https://your-frontend.vercel.app
